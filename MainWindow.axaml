<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MayinProje.MainWindow"
        Title="Mayın Tarlası"
        Width="500"
        Height="500"
        Background="#282C34"> 
    
    <Grid>
        <StackPanel Margin="10" HorizontalAlignment="Center">
               <!-- Oyuncu Adı Girişi -->
            <TextBlock Text="Oyuncu Adı" FontFamily="Arial" FontSize="14" Foreground="White" />
            <TextBox x:Name="txtPlayer" Margin="0,0,0,10" FontFamily="Arial" FontSize="14" Background="#3C4043" Foreground="Black" />
            
            <TextBlock Text="Oyun  Boyutu" Margin="0,0,0,5" FontFamily="Arial" FontSize="14" Foreground="White" />
            <TextBox x:Name="txtBoyut" Margin="0,0,0,10" FontFamily="Arial" FontSize="14" Background="#3C4043" Foreground="Black" />

            <TextBlock Text="Mayın Sayısı" FontFamily="Arial" FontSize="14" Foreground="White" />
            <NumericUpDown x:Name="MayinSayisi" Minimum="10" Maximum="100" Value="10" Margin="0,0,0,10" FontFamily="Arial" FontSize="14" Background="#3C4043" Foreground="White"/>

            <Button x:Name="btnBasla" Content="Oyun Başlat" Click="BtnBasla_OnClick" 
                    Background="#61AFEF" Padding="10" Margin="0,10,0,0" FontFamily="Arial" FontSize="14" />
            <Button x:Name="btnSkor" Content="En İyiler" Click="BtnSkor_OnClick" Margin="0,10,0,0"
                    Background="#E06C75" Padding="10" FontFamily="Arial" FontSize="14" />
            
            <!-- Hamle Sayaç -->
            <TextBlock x:Name="txtMoveCounter" IsVisible="False" Text="Hamle Sayısı: 0" Margin="0,20,0,0" FontFamily="Arial" FontSize="14" Foreground="White"/>

            <TextBlock x:Name="txtSonuc" Margin="0,10,0,0" Foreground="White" FontFamily="Arial" FontSize="14"/>
            <TextBlock x:Name="txtMesaj" Margin="0,10,0,0" Foreground="White" FontWeight="Bold" FontFamily="Arial" FontSize="14"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,5,0,0">
                <Grid x:Name="gameGrid" Background="#4E545C"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center">
                </Grid>
            </ScrollViewer>

            <TextBlock Text="Ayşe Koca" 
                       Foreground="White" 
                       Margin="0,10,0,0" FontFamily="Arial" FontSize="16"/>
            <TextBlock Text="240229089" 
                       Foreground="White" 
                       Margin="0,10,0,0" FontFamily="Arial" FontSize="16"/>
        </StackPanel>
    </Grid>
</Window>
